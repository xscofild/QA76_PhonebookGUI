<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">

<!-- Smoke suite: запускает только тесты с группой "smoky" -->
<suite name="Groups" verbose="1">
    <test name="Smoky">

        <groups>
            <run>
                <include name="smoky"/>
            </run>
        </groups>

        <!-- Только классы, где есть @Test(groups = "smoky") -->
        <classes>
            <class name="com.phonebook.tests.HomePageTests"/>
            <class name="com.phonebook.tests.AddContactTests"/>
        </classes>

    </test>
</suite>