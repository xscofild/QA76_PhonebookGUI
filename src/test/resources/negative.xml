<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">

<!-- Негативные тесты -->
<suite name="Negative" verbose="1">
    <test name="Negative Tests">
        <classes>

            <!-- В LoginTests берём только методы с Negative -->
            <class name="com.phonebook.tests.LoginTests">
                <methods>
                    <include name=".*Negative.*"/>
                </methods>
            </class>

            <!-- В CreateAccountTests берём только негативные методы -->
            <class name="com.phonebook.tests.CreateAccountTests">
                <methods>
                    <include name=".*Negative.*"/>
                </methods>
            </class>

            <!-- Отдельный класс только с негативным сценарием -->
            <class name="com.phonebook.tests.AddContactNegativeTests"/>

        </classes>
    </test>
</suite>