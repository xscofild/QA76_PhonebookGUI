<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
    hw19.xml — TestNG suite для домашнего задания Lesson 19
    Сайт: https://demowebshop.tricentis.com/

    Запуск:
      gradlew hw19
      gradlew hw19 -Pbrowser=firefox
-->

<suite name="HW19 - DemoWebShop" verbose="1" parallel="false">

    <!-- Smoke: просто открытие главной страницы -->
    <test name="HW19 - Home Page">
        <classes>
            <class name="homeworks.lesson19.tests.HW19HomePageTests"/>
        </classes>
    </test>

    <!-- Регистрация нового пользователя -->
    <test name="HW19 - New User Registration">
        <classes>
            <class name="homeworks.lesson19.tests.HW19NewUserRegisterTests"/>
        </classes>
    </test>

    <!-- Логин существующего пользователя -->
    <test name="HW19 - Existing User Login">
        <classes>
            <class name="homeworks.lesson19.tests.HW19ExistingUserRegisterTests"/>
        </classes>
    </test>

    <!-- Добавление товара в корзину -->
    <test name="HW19 - Add Item To Cart">
        <classes>
            <class name="homeworks.lesson19.tests.HW19AddItemToCartTests"/>
        </classes>
    </test>

</suite>